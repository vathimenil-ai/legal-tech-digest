# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── InnoReader ─────────────────────────────────────────────────────────────────
INOREADER_APP_ID=your_app_id
INOREADER_APP_KEY=your_app_key
# One-time OAuth token; run `python setup_inoreader.py` to populate these:
INOREADER_ACCESS_TOKEN=
INOREADER_REFRESH_TOKEN=

# ── GitHub ─────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=username/repo-name       # e.g. vathimenil/legal-intel

# ── Gmail ──────────────────────────────────────────────────────────────────────
GMAIL_USER=vathimenil@gmail.com
# OAuth credentials from Google Cloud Console (run `python setup_gmail.py` once):
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
